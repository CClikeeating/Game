.chat-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 20rpx 260rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(245, 190, 132, 0.18), transparent 34%),
    linear-gradient(180deg, #f8f4ee 0%, #f6f7f9 38%, #f4f6f8 100%);
}

.surface {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(219, 226, 235, 0.92);
  box-shadow: 0 16rpx 44rpx rgba(34, 43, 57, 0.08);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
  padding: 14rpx;
  border-radius: 22rpx;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #182127;
  border: 1rpx solid #182127;
  color: #ffffff;
  font-size: 34rpx;
  line-height: 72rpx;
}

.icon-btn.light {
  background: #f7f8fa;
}

.small-btn {
  min-width: 104rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #176b5d;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 64rpx;
}

.small-btn.soft {
  min-width: 116rpx;
  background: #f0f5f3;
  color: #176b5d;
  border: 1rpx solid #d5e4df;
}

.small-btn.ghost {
  background: #ffffff;
  color: #176b5d;
  border: 1rpx solid #c9ded8;
}

.chat-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #172033;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-subtitle {
  margin-top: 4rpx;
  color: #7b8494;
  font-size: 23rpx;
}

.quota-pill {
  flex-shrink: 0;
  min-width: 104rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #a8561d;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}

.mode-strip {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 5rpx;
  background: rgba(28, 38, 48, 0.08);
  border-radius: 12rpx;
}

.mode-pill {
  height: 44rpx;
  border-radius: 9rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #536173;
  font-size: 22rpx;
  font-weight: 700;
}

.mode-pill.active {
  background: #ffffff;
  color: #171c22;
  box-shadow: 0 6rpx 18rpx rgba(38, 52, 72, 0.08);
}

.mode-block {
  margin: 2rpx 0 10rpx;
  padding: 10rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #edf1f5;
}

.mode-row {
  display: flex;
  align-items: center;
}

.mode-help {
  margin-top: 6rpx;
  color: #7b8494;
  font-size: 21rpx;
  line-height: 1.42;
}

.quick-guide {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 58rpx;
  box-sizing: border-box;
  margin-bottom: 12rpx;
  padding: 10rpx 12rpx 10rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(23, 32, 51, 0.92);
  color: rgba(255, 255, 255, 0.86);
}

.guide-text {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.main-card,
.result-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 232, 240, 0.96);
  border-radius: 22rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 14rpx 38rpx rgba(29, 39, 53, 0.06);
}

.upload-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #e3b67d;
  background: #fff8ee;
}

.upload-panel.ready {
  border-style: solid;
  border-color: #cfe4dc;
  background: #f3faf7;
}

.upload-copy {
  flex: 1;
  min-width: 0;
}

.upload-title {
  color: #172033;
  font-size: 26rpx;
  font-weight: 850;
}

.privacy-note {
  margin-top: 6rpx;
  color: #8a6471;
  font-size: 21rpx;
  line-height: 1.42;
}

.upload-btn {
  flex-shrink: 0;
  min-width: 118rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: #176b5d;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.question-input {
  width: 100%;
  height: 104rpx;
  min-height: 104rpx;
  box-sizing: border-box;
  border: 1rpx solid #dfe6ef;
  border-radius: 16rpx;
  background: #fbfcfe;
  padding: 16rpx 18rpx;
  line-height: 1.42;
  font-size: 28rpx;
}

.compact-field {
  margin-top: 12rpx;
}

.context-input {
  width: 100%;
  height: 138rpx;
  min-height: 138rpx;
  box-sizing: border-box;
  border: 1rpx solid #dfe6ef;
  border-radius: 16rpx;
  background: #fbfcfe;
  padding: 18rpx;
  line-height: 1.45;
  font-size: 26rpx;
}

.no-margin {
  margin-bottom: 4rpx;
}

.image-item,
.result-head,
.fold-row,
.feedback-row,
.drawer-head,
.conversation-item {
  display: flex;
  align-items: center;
}

.image-list {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.image-item {
  gap: 14rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f7f9fc;
}

.image-item image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 10rpx;
}

.text-btn {
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 12rpx;
  background: transparent;
  color: #176b5d;
  font-size: 24rpx;
  line-height: 56rpx;
}

.text-btn.danger {
  color: #b42318;
}

.result-head {
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.result-head.compact {
  margin-bottom: 8rpx;
}

.result-title {
  color: #172033;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.status-dot {
  max-width: 220rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f2faf7;
  color: #176b5d;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reply-box {
  padding: 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f1fbf7 0%, #fffaf2 100%);
  border: 1rpx solid #cfe4dc;
  color: #172033;
  font-size: 30rpx;
  line-height: 1.58;
  white-space: pre-wrap;
  box-shadow: inset 6rpx 0 0 #176b5d;
}

.analysis-block,
.empty-analysis {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #edf1f5;
}

.analysis-title {
  color: #2f3b4c;
  font-size: 25rpx;
  font-weight: 850;
}

.analysis-text {
  margin-top: 8rpx;
  color: #596678;
  font-size: 25rpx;
  line-height: 1.55;
  white-space: pre-wrap;
}

.fold-row {
  justify-content: space-between;
  min-height: 72rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #2f3b4c;
  font-weight: 700;
}

.fold-content {
  padding: 18rpx 0;
  color: #596678;
  font-size: 25rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.ref-list {
  margin-top: 14rpx;
  display: grid;
  gap: 10rpx;
}

.ref-item {
  padding: 12rpx;
  border-radius: 10rpx;
  background: #f7f9fc;
}

.feedback-row {
  gap: 12rpx;
  margin-top: 20rpx;
}

.feedback-btn {
  flex: 1;
  height: 68rpx;
  border-radius: 999rpx;
  background: #f7f9fc;
  border: 1rpx solid #dfe6ef;
  color: #3b4656;
  font-size: 25rpx;
  line-height: 68rpx;
}

.feedback-note-input {
  width: 100%;
  height: 82rpx;
  min-height: 82rpx;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 14rpx;
  background: #fbfcfe;
  color: #3b4656;
  font-size: 24rpx;
  line-height: 1.4;
}

.empty-result {
  border-color: rgba(226, 232, 240, 0.82);
}

.empty-reply {
  margin-top: 12rpx;
  min-height: 92rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #d8e1eb;
  background: #f9fbfd;
  color: #7b8494;
  font-size: 27rpx;
  line-height: 1.55;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(108rpx + env(safe-area-inset-bottom));
  padding: 10rpx 24rpx 8rpx;
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid #e5eaf1;
  backdrop-filter: blur(16rpx);
}

.generate-btn {
  width: 100%;
  height: 86rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #171c22 0%, #2d333b 100%);
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 90rpx;
  box-shadow: 0 12rpx 26rpx rgba(23, 28, 34, 0.22);
}

.drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(13, 24, 38, 0.32);
  z-index: 20;
}

.drawer {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  width: 620rpx;
  max-width: 86vw;
  box-sizing: border-box;
  padding: 28rpx 22rpx;
  background: #ffffff;
  z-index: 21;
  transform: translateX(-104%);
  transition: transform 0.22s ease;
  overflow-y: auto;
  box-shadow: 18rpx 0 36rpx rgba(25, 39, 57, 0.14);
}

.drawer.open {
  transform: translateX(0);
}

.drawer-head {
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.drawer-form {
  display: grid;
  gap: 14rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.conversation-list {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
}

.conversation-item {
  align-items: flex-start;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f7f9fc;
  border: 1rpx solid transparent;
}

.conversation-item.current {
  border-color: #176b5d;
  background: #f2faf7;
}

.conversation-title {
  color: #172033;
  font-size: 27rpx;
  font-weight: 800;
}

.conversation-bg {
  margin-top: 6rpx;
  color: #7b8494;
  font-size: 23rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.conversation-actions {
  display: grid;
  gap: 4rpx;
}
