<view class="chat-page">
  <view class="topbar surface">
    <button class="icon-btn" aria-label="打开窗口" bindtap="openDrawer">☰</button>
    <view class="grow">
      <view class="chat-title">{{currentConversation.title || "默认窗口"}}</view>
    </view>
    <view class="quota-pill">剩 {{serviceReady ? limits.daily_reply_remaining : "--" }} 次</view>
  </view>

  <view class="quick-guide">
    <view class="guide-text">{{entryType === "text_only" ? "输入对方上一句话，给你一条可参考的接话。" : "上传截图，给你一条可参考的接话。"}}</view>
    <button class="small-btn soft" bindtap="startNewConversation">新窗口</button>
  </view>

  <view class="entry-strip surface">
    <view class="entry-pill {{entryType === 'screenshot' ? 'active' : ''}}" data-entry="screenshot" bindtap="selectEntry">
      <view>上传截图</view>
    </view>
    <view class="entry-pill {{entryType === 'text_only' ? 'active' : ''}}" data-entry="text_only" bindtap="selectEntry">
      <view>文字输入</view>
    </view>
  </view>

  <view class="main-card">
    <view wx:if="{{entryType === 'screenshot'}}" class="upload-panel {{images.length ? 'ready' : ''}}">
      <view class="upload-copy">
        <view class="upload-title">{{images.length ? "已上传截图" : "请上传截图"}}</view>
        <view class="muted">最多 {{limits.max_images_per_reply || 3}} 张，单张 {{limits.max_image_mb || 8}}MB。需要截图后才能继续。</view>
      </view>
      <button class="upload-btn" bindtap="chooseImages">{{images.length ? "继续加" : "上传"}}</button>
    </view>

    <view wx:if="{{entryType === 'screenshot' && images.length}}" class="image-list">
      <view wx:for="{{images}}" wx:key="tempFilePath" class="image-item">
        <image src="{{item.tempFilePath}}" mode="aspectFill"></image>
        <view class="grow muted">{{item.sizeText}}</view>
        <button class="text-btn" data-index="{{index}}" bindtap="removeImage">删除</button>
      </view>
    </view>

    <view class="compact-field">
      <view class="label">{{entryType === "text_only" ? "对方上一句话" : "当前问题"}}</view>
      <textarea class="question-input" placeholder="{{entryType === 'text_only' ? '把对方上一句话粘到这里' : '我该怎么回'}}" value="{{question}}" bindinput="onQuestionInput"></textarea>
    </view>

    <view class="compact-field">
      <view class="label">补充背景</view>
      <textarea class="context-input" placeholder="可选：认识多久、关系阶段、你想达到什么效果" value="{{context}}" bindinput="onContextInput"></textarea>
    </view>
  </view>

  <view wx:if="{{result}}" class="result-card">
    <view class="result-head">
      <view class="grow">
        <view class="result-title">推荐接话</view>
      </view>
      <view class="status-dot">{{result.status}}</view>
    </view>
    <view class="mode-block">
      <view class="mode-row">
        <view class="mode-strip {{entryType === 'text_only' ? 'one' : ''}}">
          <view class="mode-pill {{mode === 'bailian_rag_fast' ? 'active' : ''}}" data-mode="bailian_rag_fast" bindtap="selectMode">日常接话 · {{fastCost}} 积分</view>
          <view wx:if="{{entryType === 'screenshot'}}" class="mode-pill {{mode === 'bailian_rag_strategy_quality' ? 'active' : ''}}" data-mode="bailian_rag_strategy_quality" bindtap="selectMode">暧昧推荐 · {{strategyCost}} 积分</view>
        </view>
      </view>
      <view class="mode-help">{{entryType === "text_only" ? "文字输入固定使用日常接话。" : "上传截图默认使用暧昧推荐，也可切到日常接话。"}}</view>
    </view>
    <view class="reply-box">{{result.answer.reply || "暂无内容"}}</view>

    <view class="analysis-block">
      <view class="analysis-title">分析</view>
      <view class="analysis-text">{{result.answer.coach_analysis || "无"}}</view>
    </view>

    <view class="feedback-row">
      <button class="feedback-btn" data-rating="good" bindtap="sendFeedback">好</button>
      <button class="feedback-btn" data-rating="ok" bindtap="sendFeedback">还行</button>
      <button class="feedback-btn" data-rating="bad" bindtap="sendFeedback">不好</button>
    </view>
    <textarea class="feedback-note-input" placeholder="反馈备注，可选" value="{{feedbackNotes}}" bindinput="onFeedbackNotesInput"></textarea>
  </view>

  <view wx:else class="result-card empty-result">
    <view class="result-head compact">
      <view class="result-title">推荐接话</view>
    </view>
    <view class="mode-block">
      <view class="mode-row">
        <view class="mode-strip {{entryType === 'text_only' ? 'one' : ''}}">
          <view class="mode-pill {{mode === 'bailian_rag_fast' ? 'active' : ''}}" data-mode="bailian_rag_fast" bindtap="selectMode">日常接话 · {{fastCost}} 积分</view>
          <view wx:if="{{entryType === 'screenshot'}}" class="mode-pill {{mode === 'bailian_rag_strategy_quality' ? 'active' : ''}}" data-mode="bailian_rag_strategy_quality" bindtap="selectMode">暧昧推荐 · {{strategyCost}} 积分</view>
        </view>
      </view>
      <view class="mode-help">{{entryType === "text_only" ? "文字输入固定使用日常接话。" : "上传截图默认使用暧昧推荐，也可切到日常接话。"}}</view>
    </view>
    <view class="empty-reply">{{entryType === "text_only" ? "输入文字后，结果会出现在这里。" : "上传截图后，结果会出现在这里。"}}</view>
    <view class="empty-analysis">
      <view class="analysis-title">分析</view>
      <view class="analysis-text">开始后会一起展示为什么这么处理。</view>
    </view>
  </view>

  <view class="bottom-action">
    <button class="generate-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="submitReply">开始</button>
  </view>

  <view wx:if="{{drawerOpen}}" class="drawer-mask" bindtap="closeDrawer"></view>
  <view class="drawer {{drawerOpen ? 'open' : ''}}">
    <view class="drawer-head">
      <view>
        <view class="section-title">窗口</view>
        <view class="muted">最多 {{limits.max_conversations_per_user || 0}} 个</view>
      </view>
      <button class="icon-btn light" bindtap="closeDrawer">×</button>
    </view>

    <view class="drawer-form">
      <input class="input" placeholder="窗口名称" value="{{draftTitle}}" bindinput="onDraftTitleInput" />
      <textarea class="textarea small" placeholder="这个窗口的长期背景" value="{{draftBackground}}" bindinput="onDraftBackgroundInput"></textarea>
      <button class="button" bindtap="saveConversation">{{editingId ? "保存窗口" : "新建窗口"}}</button>
    </view>

    <view class="conversation-list">
      <view wx:for="{{conversations}}" wx:key="conversation_id" class="conversation-item {{item.conversation_id === currentConversation.conversation_id ? 'current' : ''}}">
        <view class="grow" data-id="{{item.conversation_id}}" bindtap="selectConversation">
          <view class="conversation-title">{{item.title}}</view>
          <view class="conversation-bg">{{item.background || "未填写背景"}}</view>
        </view>
        <view class="conversation-actions">
          <button class="text-btn" data-id="{{item.conversation_id}}" data-title="{{item.title}}" data-background="{{item.background}}" bindtap="editConversation">编辑</button>
          <button class="text-btn danger" data-id="{{item.conversation_id}}" bindtap="deleteConversation">归档</button>
        </view>
      </view>
    </view>
  </view>
</view>
