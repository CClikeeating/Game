.tab-safe {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 10rpx 22rpx calc(10rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid rgba(222, 229, 238, 0.95);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -12rpx 34rpx rgba(31, 42, 58, 0.08);
  box-sizing: border-box;
}

.tabbar {
  height: 88rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  align-items: center;
}

.tab-item {
  height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #697386;
  font-size: 27rpx;
  font-weight: 750;
  line-height: 1.2;
}

.tab-item.active {
  background: #f3f4f6;
  color: #171c22;
  font-size: 29rpx;
  font-weight: 900;
}

.tab-mark {
  width: 30rpx;
  height: 5rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  background: transparent;
}

.tab-item.active .tab-mark {
  background: #171c22;
}

.tab-text {
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
