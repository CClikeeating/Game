<view class="tab-safe">
  <view class="tabbar">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-mark"></view>
      <view class="tab-text">{{item.text}}</view>
    </view>
  </view>
</view>
