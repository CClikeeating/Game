page {
  background: #f8f4ee;
  color: #1d2735;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

button {
  margin: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 140rpx;
}

.panel {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 232, 240, 0.96);
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 38rpx rgba(29, 39, 53, 0.06);
}

.section-title {
  color: #1d2735;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.label {
  color: #3b4656;
  font-size: 25rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #7b8494;
  font-size: 24rpx;
  line-height: 1.5;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #dfe6ef;
  border-radius: 10rpx;
  background: #fbfcfe;
  color: #1d2735;
  padding: 18rpx;
  font-size: 27rpx;
  line-height: 1.55;
}

.input {
  min-height: 76rpx;
}

.textarea {
  min-height: 156rpx;
}

.textarea.small {
  min-height: 96rpx;
}

.button {
  min-height: 76rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #176b5d 0%, #1d7b68 100%);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
}

.button.secondary {
  background: #eef4f2;
  color: #155448;
  border: 1rpx solid #c9ded8;
}

.button.ghost {
  background: #ffffff;
  color: #3b4656;
  border: 1rpx solid #dfe6ef;
}

.row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.grow {
  flex: 1;
  min-width: 0;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  border: 1rpx solid #d8e4e0;
  color: #155448;
  background: #f4faf8;
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
  font-size: 24rpx;
}

.chip.active {
  background: #176b5d;
  border-color: #176b5d;
  color: #ffffff;
}
